# Font configuration
font-size = {{font_size}}
font-family = "{{font_family}}"

font-family-italic = "{{font_family_italic}}"
font-family-bold-italic = "{{font_family_italic}}"

# font-thicken = true
font-style = "Medium"

# Increase line spacing by
adjust-cell-height = 10%

# Background settings
background-blur = 20
background-opacity = 1.0

# Theme configuration
theme = light:TokyoNight Day,dark:TokyoNight Moon

# Window dimensions
window-width = 130
window-height = 35
window-save-state = always

# Appearance settings
scrollback-limit = 5242880
mouse-hide-while-typing = true
# makes borders much nicer, especially with nvim
window-padding-balance = true
window-padding-color = extend

# MacOS tweaks
macos-option-as-alt = left
macos-titlebar-style = tabs

# Shell Tweaks
shell-integration = fish
shell-integration-features = sudo,ssh-terminfo,ssh-env
# OSC-52 passthrough for nvim unnamedplus
clipboard-read = allow
clipboard-write = allow

# Advanced tweaks
quit-after-last-window-closed = true
copy-on-select = clipboard
